{
  "name": "collectiv-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Dev: npm run dev → http://127.0.0.1:3333 (binds 0.0.0.0). Unstyled preview / missing CSS? npm run clean && npm run dev; use port 3333 (not 3000). EMFILE: dev:clean or dev:poll; macOS: ulimit -n 10240 first.",
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "ulimit -n 10240 2>/dev/null || true; next dev -p 3333 -H 0.0.0.0",
    "dev:kill-port": "lsof -ti :3333 | xargs kill -9 2>/dev/null || true",
    "dev:clean": "npm run clean && (ulimit -n 10240 2>/dev/null || true) && next dev -p 3333 -H 0.0.0.0",
    "dev:poll": "ulimit -n 10240 2>/dev/null || true; WATCHPACK_POLLING=true next dev -p 3333 -H 0.0.0.0",
    "dev:clean:poll": "npm run clean && (ulimit -n 10240 2>/dev/null || true) && WATCHPACK_POLLING=true next dev -p 3333 -H 0.0.0.0",
    "dev:loopback": "next dev -p 3333 -H 127.0.0.1",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start -p 3333",
    "preview": "npm run build && npm run start",
    "export": "NEXT_STATIC_EXPORT=1 next build",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "pusher": "^5.3.3",
    "pusher-js": "^8.4.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
