# Copy to `.env` for local development.

# --- Vercel Production (Settings → Environment Variables → Production; then Redeploy) ---
# Minimum to stop generic production errors / Prisma / NextAuth issues:
#   DATABASE_URL   — Supabase transaction pooler, user postgres, host db.<ref>.supabase.co:6543
#                    ?pgbouncer=true&sslmode=require
#   DIRECT_URL     — same as local (often 5432 direct, or duplicate DATABASE_URL if only pooler works)
#   NEXTAUTH_URL   — exact browser URL, e.g. https://your-app.vercel.app (https, no stray slash mismatch)
#   NEXTAUTH_SECRET — openssl rand -base64 32
# Optional but needed for studio dashboards: STUDIO_EMAIL (comma-separated, matches User emails)
# Sanity-check locally: npm run check:vercel-env  (reads .env if present)
#
# Temporary diagnostics (same AUTH_DIAGNOSTIC_SECRET): redeploy, hit once, then unset the var.
#   GET /api/test-auth?secret=...     — DB + Harriet user (no password hash)
#   GET /api/test-instagram?secret=... — Instagram env + Graph lastError (no access token)
# AUTH_DIAGNOSTIC_SECRET=""

# PostgreSQL — Prisma: url + directUrl (often same URI locally).
# Supabase Transaction pooler (6543): user is `postgres`, host is `db.<project-ref>.supabase.co` (not aws-*-pooler unless Session mode).
#   DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&sslmode=require"
# If direct 5432 is blocked, set DIRECT_URL to the same 6543 URI (or use Session pooler from the dashboard for migrations only).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&sslmode=require"

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: SQLite for local-only experiments (not used when DATABASE_URL is PostgreSQL)
# DATABASE_URL="file:./prisma/dev.db"

# Create schema and demo users (required for /portal):
#   npx prisma migrate dev
#   npm run seed
#
# --- Local test logins (after seed) ---
# Client (Riverside walkthrough — Website + Social + Branding + Signage projects):
#   client-walkthrough@collectiv.local  /  collectiv-walkthrough
# Agency (full studio dashboard):
#   agency@example.com  /  agency-demo-password
# Team personas (each password is unique; all must appear in STUDIO_EMAIL to sign in as studio):
#   isabella@collectiv.local   /  collectiv-test-issy
#   harriet@collectiv.local    /  collectiv-test-harriet
#   may@collectiv.local        /  collectiv-test-may
# If STUDIO_EMAIL’s first entry is an email with no User yet, seed also creates it with:
#   studio-password-change-me  (see seed console output)

# Required on real HTTPS deploys: long random string (openssl rand -base64 32). Dev / local http preview can omit — fallbacks apply.
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Must match the URL you open in the browser (localhost vs 127.0.0.1 matters for cookies). Use https://… in production.
NEXTAUTH_URL="http://127.0.0.1:3333"

# Comma-separated emails that get full studio access (any project). Include named team logins for their dashboards:
STUDIO_EMAIL="agency@example.com,harriet@collectiv.local,isabella@collectiv.local,may@collectiv.local"
#
# Optional: map logins to personas for personal dashboards + routed auto to-dos (see lib/studio-team-config.ts).
# Issy (isabella): operations, project flow, calendar org, assigning, client comms.
# Harriet: designer & business owner.
# May: social clients, processes, calendar sign-off (Issy oversees flow).
# Emails must match User rows and appear in STUDIO_EMAIL.
# STUDIO_PERSONA_ISABELLA_EMAIL="isabella@yourdomain.com"
# STUDIO_PERSONA_HARRIET_EMAIL="harriet@yourdomain.com"
# STUDIO_PERSONA_MAY_EMAIL="may@yourdomain.com"
#
# Seed creates isabella / harriet / may @collectiv.local with collectiv-test-* passwords (see list above).

# --- Home page Instagram grid (optional) ---
# Long-lived tokens expire ~60 days — when the grid vanishes, generate a new token in Meta and update Vercel, redeploy.
# The home page calls Meta’s API server-side. Old “Basic Display” tokens (IGAA…) are deprecated — create a new token.
#
# Instagram Login (consumer/creator): leave base URL unset; uses https://graph.instagram.com/.../me/media
# Instagram Business/Creator linked to a Facebook Page: set all three:
#   INSTAGRAM_GRAPH_BASE_URL="https://graph.facebook.com"
#   INSTAGRAM_USER_ID="<numeric Instagram account id>"   # Graph API Explorer or Page → Instagram settings
#   INSTAGRAM_ACCESS_TOKEN="<long-lived Page or User token with instagram_basic / instagram_manage_insights etc.>"
#
# Copy the same variables to Vercel → Project → Settings → Environment Variables (Production) and redeploy.
# Docs: https://developers.facebook.com/docs/instagram-platform/instagram-api-with-instagram-login
INSTAGRAM_ACCESS_TOKEN=""
# INSTAGRAM_GRAPH_BASE_URL="https://graph.facebook.com"
# Required when using graph.facebook.com; optional on graph.instagram.com (then /me/media is used).
INSTAGRAM_USER_ID=""
# Your public profile link (footer + section use this). Overrides default collectiv.studio.
# INSTAGRAM_PROFILE_URL="https://www.instagram.com/your_handle/"
# Optional API version path segment (default: v21.0).
# INSTAGRAM_GRAPH_API_VERSION="v21.0"

# Optional: POST JSON when a client completes portal registration — use Zapier/Make to email the studio.
# Body includes: event, email, name, registeredAt, message
# PORTAL_STUDIO_NOTIFY_WEBHOOK="https://hooks.zapier.com/..."

# Optional: real email via Resend (https://resend.com). If set, studio gets an email on client registration.
# RESEND_API_KEY=""
# STUDIO_NOTIFICATION_EMAIL="you@yourdomain.com"   # defaults to first STUDIO_EMAIL if omitted
# RESEND_FROM_EMAIL="Collectiv <hello@yourdomain.com>"
#
# With RESEND_API_KEY set, clients also get stage emails (new calendar content, review uploads, studio messages,
# quote sent, account verified, discovery approved, live URL, project complete, new project). Links use NEXTAUTH_URL.
# Set PORTAL_CLIENT_EMAIL_ALERTS=0 to turn client alerts off while keeping studio registration email.
# PORTAL_CLIENT_EMAIL_ALERTS=""

# Optional: POST JSON { "email", "source": "launch-modal" } when someone signs up from the home launch popup (e.g. Zapier, Make, or your CRM webhook).
# LAUNCH_SIGNUP_WEBHOOK="https://hooks.zapier.com/..."

# Optional: Pusher — instant calendar refresh for open portal pages (channel project-{projectId}-calendar, event refresh).
# Server: PUSHER_APP_ID, PUSHER_SECRET. Client: NEXT_PUBLIC_PUSHER_KEY, NEXT_PUBLIC_PUSHER_CLUSTER (e.g. eu).
# If omitted, the calendar still updates on a light polling interval.
# PUSHER_APP_ID=""
# PUSHER_SECRET=""
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER=""

# Optional: OpenAI API key for the marketing-site quick-questions chat (gpt-4o-mini). Without it, chat still works using FAQs and a short fallback message.
# OPENAI_API_KEY=""

# Required in production if clients save social account logins in the portal. Long random string (e.g. openssl rand -base64 48).
# Dev omits — a deterministic dev-only key is used (never deploy without setting this).
# SOCIAL_ACCOUNT_ACCESS_SECRET=""
#
# Optional separate secret for encrypted domain registrar logins on the website “domain & go live” page.
# If unset, SOCIAL_ACCOUNT_ACCESS_SECRET is used (one secret for both vaults is fine).
# WEBSITE_DOMAIN_ACCESS_SECRET=""
